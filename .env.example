# LLM Provider: "openai" or "gemini"
LLM_PROVIDER=gemini

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your-google-api-key-here

# Database URL
# For PostgreSQL: postgresql://user:password@localhost:5432/doc_pipeline
# For SQLite (default): sqlite:///./doc_pipeline.db
DATABASE_URL=sqlite:///./doc_pipeline.db

# Webhook Secret (for validating incoming webhooks)
WEBHOOK_SECRET=your-webhook-secret-here

# Server
HOST=0.0.0.0
PORT=8000
